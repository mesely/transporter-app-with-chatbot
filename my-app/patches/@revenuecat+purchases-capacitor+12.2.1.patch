+import Foundation
+import Capacitor
+
+#if compiler(>=5.3) && $NonescapableTypes
+// Capacitor APIs are available as-is.
+#else
+extension CAPPluginCall {
+    @objc func reject(_ message: String, _ code: String? = nil, _ error: Error? = nil, _ data: PluginCallResultData? = nil) {
+        unavailable(message)
+    }
+
+    func getString(_ key: String) -> String? {
+        let value = getString(key, "")
+        return value.isEmpty ? nil : value
+    }
+
+    func getBool(_ key: String) -> Bool? {
+        if let value = options[key] as? Bool {
+            return value
+        }
+        return nil
+    }
+
+    func getArray(_ key: String) -> JSArray? {
+        if let value = options[key] as? JSArray {
+            return value
+        }
+        return nil
+    }
+
+    func getObject(_ key: String) -> JSObject? {
+        if let value = options[key] as? JSObject {
+            return value
+        }
+        return nil
+    }
+}
+
+#endif
